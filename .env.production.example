# Store real values in the cloud provider secret manager. Never commit them.
NODE_ENV=production
PORT=8080
PUBLIC_BASE_URL=https://YOUR_DOMAIN

# Server-side DeepSeek configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
LLM_MAX_ATTEMPTS=3

# Locked production behavior
ALLOW_RUNTIME_SETTINGS=false
OLLAMA_FALLBACK=false
RAG_ENABLED=false
RSS_ENABLED=false

# Optional administrator bearer token. Users authenticate with account sessions.
API_TOKEN=
SESSION_DAYS=30
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Claudio <hello@YOUR_DOMAIN>

# Daily AI reply limits and estimated model cost rates
FREE_DAILY_MESSAGES=10
PRO_DAILY_MESSAGES=200
LLM_INPUT_USD_PER_MILLION=
LLM_OUTPUT_USD_PER_MILLION=

# Single-instance abuse protection
# Enable only when the hosting reverse proxy overwrites X-Forwarded-For.
TRUST_PROXY=true
AUTH_RATE_WINDOW_MS=900000
REGISTER_IP_LIMIT=5
LOGIN_IP_LIMIT=20
LOGIN_ACCOUNT_LIMIT=10
CHAT_RATE_WINDOW_MS=60000
CHAT_ACCOUNT_LIMIT=30
CHAT_IP_LIMIT=60

# Legacy generic billing webhook. Not required by WeChat Pay or Alipay checkout.
BILLING_WEBHOOK_SECRET=

# Mainland China checkout. Configure at least one complete channel.
# Use public HTTPS callback URLs and store all keys in the cloud secret manager.
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=https://YOUR_DOMAIN/api/payments/wechat/notify

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_NOTIFY_URL=https://YOUR_DOMAIN/api/payments/alipay/notify

# Error monitoring is required before public launch.
MONITORING_DSN=

# LLM 配置
NODE_ENV=development

LLM_PROVIDER=auto
LLM_MAX_RETRIES=1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Claude CLI(当 LLM_PROVIDER=claude 或 auto 且无 OPENAI_API_KEY)
CLAUDE_MODEL=claude-opus-4-7[1m]

# Ollama 离线降级（需本地运行 ollama serve，提前 pull 模型）
# 启用后主 LLM 不可用时自动切换 Ollama
OLLAMA_FALLBACK=true
# 本地模型名（推荐 qwen2.5:3b，3B 参数适合消费级硬件）
OLLAMA_MODEL=qwen2.5:3b
# Ollama API 地址（默认本地）
OLLAMA_BASE_URL=http://localhost:11434

# 天气
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Beijing,CN

# 对话历史注入条数(轮,每轮 user+assistant)
CONTEXT_HISTORY_SLICES=6

# LLM 失败时最多请求次数(含首次,默认 2 = 重试 1 次)
LLM_MAX_ATTEMPTS=3
PUBLIC_BASE_URL=http://localhost:8080
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional single-instance abuse protection overrides
TRUST_PROXY=false
AUTH_RATE_WINDOW_MS=900000
REGISTER_IP_LIMIT=5
LOGIN_IP_LIMIT=20
LOGIN_ACCOUNT_LIMIT=10
CHAT_RATE_WINDOW_MS=60000
CHAT_ACCOUNT_LIMIT=30
CHAT_IP_LIMIT=60

# Optional signed billing webhook
BILLING_WEBHOOK_SECRET=

# Mainland China checkout: configure at least one complete channel.
# Keep PEM keys on the server; use \n for line breaks in a single-line env value.
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=http://localhost:8080/api/payments/wechat/notify

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_NOTIFY_URL=http://localhost:8080/api/payments/alipay/notify

MONITORING_DSN=

# WebSocket 心跳间隔(ms)
# WS_PING_MS=25000

# 飞书日程骨架:复制 data/feishu-schedule.example.json → data/feishu-schedule.json
# FEISHU_SCHEDULE_PATH=data/feishu-schedule.json

# Fish Audio TTS(可选)
FISH_AUDIO_API_KEY=
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_REFERENCE_ID=

# API 鉴权(可选,设置后 POST /api/chat 需 Bearer token)
API_TOKEN=
ALLOW_RUNTIME_SETTINGS=true

# 服务端口
PORT=8080

# RAG 向量记忆（语义检索）
# 启用后每次对话会从历史/品味档案中检索相关记忆
RAG_ENABLED=true
# 嵌入服务独立配置（当主 LLM 不支持 embedding 时使用，回退复用 OPENAI_*）
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# RSS 资讯注入（注入 system prompt，让电台能聊时事）
RSS_ENABLED=false
# 逗号分隔的 RSS 源 URL，留空使用内置默认（少数派/果壳/36氪/知乎）
# RSS_SOURCES=
RSS_MAX_ITEMS=5
